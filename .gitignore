security_check.md

# Python bytecode
__pycache__/
*.py[cod]
*$py.class

# Python extensions / packaging
*.so
.Python
build/
dist/
.eggs/
*.egg-info/
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment files
.env
.env.*

# Django runtime artifacts
db.sqlite3
db.sqlite3-journal
media/
staticfiles/
*.log
local_settings.py

# Test and analysis caches
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.hypothesis/
.tox/
.nox/

# Editor / OS files
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Node package artifacts (if frontend tooling is added later)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# since there is scripts to transform .jpg to .svg, we can ignore .jpg files
*.jpg
media/*.png
