# -----------------------------------------------------------------------------
# Django core
# -----------------------------------------------------------------------------
# Required: set to a strong random value (50+ chars recommended).
DJANGO_SECRET_KEY=replace-with-a-strong-random-secret-key
DJANGO_DEBUG=False

# Comma-separated hostnames.
# Include your Azure app hostname, e.g. myapp.azurewebsites.net
DJANGO_ALLOWED_HOSTS=.azurewebsites.net

# Comma-separated full origins with scheme.
# Include your Azure app URL, e.g. https://myapp.azurewebsites.net
DJANGO_CSRF_TRUSTED_ORIGINS=https://*.azurewebsites.net

# -----------------------------------------------------------------------------
# Database (Azure PostgreSQL)
# -----------------------------------------------------------------------------
DJANGO_DB_ENGINE=postgresql
DJANGO_DB_NAME=replace-with-db-name
DJANGO_DB_USER=replace-with-db-user
DJANGO_DB_PASSWORD=replace-with-db-password
DJANGO_DB_HOST=replace-with-db-host.postgres.database.azure.com
DJANGO_DB_PORT=5432

# Optional DB connection options
DJANGO_DB_SSLMODE=require
DJANGO_DB_SSLROOTCERT=
DJANGO_DB_CONNECT_TIMEOUT=10

# -----------------------------------------------------------------------------
# Local-test toggle
# -----------------------------------------------------------------------------
# Keep False in Azure production.
LOCAL_TEST=False
DJANGO_LOCAL_DB_USER=
DJANGO_LOCAL_DB_PASSWORD=
DJANGO_LOCAL_DB_HOST=

# -----------------------------------------------------------------------------
# Management access gate
# -----------------------------------------------------------------------------
DJANGO_MANAGEMENT_ACCESS_ENABLED=False
DJANGO_MANAGEMENT_ACCESS_CODE=replace-with-management-access-code
DJANGO_MANAGEMENT_ACCESS_SESSION_AGE_SECS=14400

# -----------------------------------------------------------------------------
# Capture access gate (separate from management)
# -----------------------------------------------------------------------------
DJANGO_CAPTURE_ACCESS_ENABLED=False
DJANGO_CAPTURE_ACCESS_CODE=replace-with-capture-access-code
DJANGO_CAPTURE_ACCESS_SESSION_AGE_SECS=14400

# -----------------------------------------------------------------------------
# Media/object storage
# -----------------------------------------------------------------------------
DJANGO_MEDIA_URL=/media/
DJANGO_MEDIA_ROOT=/home/site/wwwroot/media
DJANGO_OBJECT_STORAGE_PREFIX=objects

# Option A (local filesystem in container)
# DJANGO_OBJECT_STORAGE_BACKEND=django.core.files.storage.FileSystemStorage

# Option B (recommended for Azure): Blob Storage backend
DJANGO_OBJECT_STORAGE_BACKEND=storages.backends.azure_storage.AzureStorage
AZURE_CONTAINER=replace-with-container-name

# Choose one Azure auth strategy:
# 1) Connection string
AZURE_CONNECTION_STRING=

# 2) Account key
AZURE_ACCOUNT_NAME=
AZURE_ACCOUNT_KEY=

# 3) SAS token
AZURE_SAS_TOKEN=

# 4) Managed identity
AZURE_USE_MANAGED_IDENTITY=False
AZURE_MANAGED_IDENTITY_CLIENT_ID=

AZURE_CUSTOM_DOMAIN=
AZURE_ENDPOINT_SUFFIX=core.windows.net
AZURE_LOCATION=
AZURE_CACHE_CONTROL=
AZURE_SSL=True
AZURE_OVERWRITE_FILES=False
AZURE_UPLOAD_MAX_CONN=2
AZURE_CONNECTION_TIMEOUT_SECS=20
AZURE_BLOB_MAX_MEMORY_SIZE=2097152
AZURE_URL_EXPIRATION_SECS=

# -----------------------------------------------------------------------------
# Asset fetching/sync
# -----------------------------------------------------------------------------
DJANGO_ASSETS_BASE_URL=
DJANGO_BUILDINGS_MANIFEST_URL=
DJANGO_BUILDINGS_MANIFEST_TIMEOUT_SECS=10
DJANGO_ASSET_PROXY_ALLOWED_HOSTS=hubhumanactivities.blob.core.windows.net
DJANGO_SYNC_BUILDINGS_ON_MIGRATE=True

# -----------------------------------------------------------------------------
# Security cookie settings
# -----------------------------------------------------------------------------
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_X_FRAME_OPTIONS=SAMEORIGIN
